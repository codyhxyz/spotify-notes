# Neon Postgres pooled connection string (copy from Neon console).
# Format: postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Spotify OAuth app credentials. Used by NextAuth's Spotify provider
# (lib/auth.ts). Create / view these at https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth secret used to sign JWTs / encrypt cookies. REQUIRED in all envs.
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Canonical site URL. Required in production (Vercel sets VERCEL_URL but
# NextAuth v4 prefers an explicit value). For local dev, http://localhost:3000.
NEXTAUTH_URL=http://localhost:3000
