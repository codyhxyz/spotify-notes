# Neon Postgres pooled connection string (copy from Neon console).
# Format: postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Spotify OAuth app credentials. Used by NextAuth's Spotify provider
# (lib/auth.ts). Create / view these at https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Auth.js v5 secret used to sign JWTs / encrypt cookies. REQUIRED in all envs.
# Generate with: `openssl rand -base64 32`. The legacy NEXTAUTH_SECRET name
# is still honored as a fallback so prod env doesn't have to be renamed in
# lockstep with the v4→v5 deploy.
AUTH_SECRET=

# Canonical site URL. Auto-detected on Vercel; set explicitly for local dev
# and self-host. AUTH_URL is the v5 name; NEXTAUTH_URL still works.
AUTH_URL=http://localhost:3000
